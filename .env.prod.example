# Copy this to .env.prod and set real secrets before starting Docker Compose.
# Optional: pass VERSION=v0.1.0 to make up to pin the app build version.
BLOG_PORT=8080
SITE_BASE_URL=http://127.0.0.1:8080

SESSION_SECRET=replace-with-at-least-32-random-bytes
API_TOKEN=

# Leave both empty for an unauthenticated local Redis.
REDIS_USERNAME=
REDIS_PASSWORD=
